{
  "model": "Qwen/Qwen2.5-0.5B-Instruct",
  "training_file": "",
  "max_seq_length": 2048,
  "load_in_4bit": false,
  "loss": "sft",
  "is_peft": true,
  "target_modules": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj",
    "gate_proj",
    "up_proj",
    "down_proj"
  ],
  "lora_bias": "none",
  "r": 32,
  "lora_alpha": 64,
  "lora_dropout": 0,
  "use_rslora": true,
  "merge_before_push": false,
  "push_to_private": true,
  "epochs": 1,
  "eight_bit": true,
  "max_steps": 1,
  "per_device_train_batch_size": 8,
  "gradient_accumulation_steps": 2,
  "warmup_steps": 5,
  "learning_rate": 1e-05,
  "logging_steps": 1,
  "optim": "adamw_8bit",
  "weight_decay": 0.01,
  "lr_scheduler_type": "linear",
  "seed": 42,
  "save_strategy": "epoch",
  "save_steps": 500,
  "output_dir": ""
}